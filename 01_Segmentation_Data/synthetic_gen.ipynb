import pandas as pd
import numpy as np
import uuid
from datetime import datetime, timedelta

def generate_tvc_outreach_dataset(records=10000):
    """
    Generates a high-fidelity synthetic dataset for the TVO-MI Portfolio Project.
    Aligned with TVC Strategic Priority #3 (Support Services Database).
    """
    np.random.seed(42)  # For reproducibility in audit

    # 1. Define Categorical Distributions based on TVC 2024/2026 Reports
    eras = ['Gulf War Era II', 'Gulf War Era I', 'Vietnam', 'Korea', 'WWII']
    era_weights = [0.34, 0.29, 0.32, 0.04, 0.01]

    genders = ['Male', 'Female', 'Other']
    gender_weights = [0.83, 0.15, 0.02]

    counties = ['Urban', 'Rural']
    county_weights = [0.70, 0.30]

    programs = ['Claims', 'Education', 'Employment', 'Health Care Advocacy', 'Mental Health', 'None']

    # 2. Generate Base Data
    data = {
        'veteran_id': [str(uuid.uuid4())[:8].upper() for _ in range(records)],
        'gender': np.random.choice(genders, records, p=gender_weights),
        'era_of_service': np.random.choice(eras, records, p=era_weights),
        'county_type': np.random.choice(counties, records, p=county_weights),
        'disability_rating': np.random.choice(range(0, 101, 10), records), # Assuming disability ratings from 0 to 100 in steps of 10
        'engaged_program': np.random.choice(programs, records, p=[0.25, 0.15, 0.15, 0.15, 0.10, 0.20]),
        'is_pact_act_eligible': np.random.choice([True, False], records, p=[0.45, 0.55])
    }

    df = pd.DataFrame(data)

    # 3. DPSCL BIAS INJECTION (Simulating the "Awareness Gap")
    # Logic: If a veteran is Female AND Rural, we simulate a lack of engagement
    # This reflects the TCCVS report findings on rural accessibility barriers.

    # Generate engagement days (0 to 730 days / 2 years)
    df['last_engagement_days_ago'] = np.random.randint(0, 500, records)

    # Inject 14% higher engagement gap for Rural Females (Scenario Problem Statement)
    mask = (df['gender'] == 'Female') & (df['county_type'] == 'Rural')
    df.loc[mask, 'last_engagement_days_ago'] += np.random.randint(200, 400, size=mask.sum())

    # Simulate clicks (Success Metric) - Rural cohorts have lower digital interaction due to broadband issues
    df['outreach_clicks'] = np.random.poisson(lam=3, size=records)
    df.loc[df['county_type'] == 'Rural', 'outreach_clicks'] = np.random.poisson(lam=1, size=(df['county_type'] == 'Rural').sum())

    # 4. Data Quality Check
    # Ensure disability ratings for Gulf War II are correctly skewed higher
    gw2_mask = (df['era_of_service'] == 'Gulf War Era II')
    df.loc[gw2_mask, 'disability_rating'] = np.random.choice(range(50, 101, 10), size=gw2_mask.sum())

    # 5. Export Deliverable
    filename = "01_Segmentation_Data/Synthetic_Veteran_Constituent_Dataset.csv"
    # Ensure directory exists in your local repo structure
    import os
    if not os.path.exists('01_Segmentation_Data'):
        os.makedirs('01_Segmentation_Data')

    df.to_csv(filename, index=False)

    print(f"PHASE I COMPLETE: {records} records generated and saved to {filename}")
    return df

# Execute Generation
tvc_df = generate_tvc_outreach_dataset(10000)

# Display head for Director's review
print(tvc_df.head())
