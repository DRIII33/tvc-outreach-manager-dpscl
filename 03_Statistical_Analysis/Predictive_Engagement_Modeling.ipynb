import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
from scipy import stats
import os # Import the os module

# Load the validated dataset from Phase I/II
df = pd.read_csv('01_Segmentation_Data/Synthetic_Veteran_Constituent_Dataset.csv')

# Create the output directory if it doesn't exist
output_dir = '03_Statistical_Analysis'
if not os.path.exists(output_dir):
    os.makedirs(output_dir)

# 1. SCIENTIFIC HYPOTHESIS TESTING
# Null Hypothesis (H0): There is no difference in engagement between Urban and Rural veterans.
# Alternative Hypothesis (H1): Rural veterans face significantly higher engagement barriers.

urban_days = df[df['county_type'] == 'Urban']['last_engagement_days_ago']
rural_days = df[df['county_type'] == 'Rural']['last_engagement_days_ago']

t_stat, p_val = stats.ttest_ind(urban_days, rural_days)

print("--- HYPOTHESIS TEST RESULTS ---")
print(f"T-Statistic: {t_stat:.4f}")
print(f"P-Value: {p_val:.4f}")

if p_val < 0.05:
    print("RESULT: Reject Null Hypothesis. The rural engagement gap is STATISTICALLY SIGNIFICANT.")
else:
    print("RESULT: Fail to Reject Null Hypothesis.")

# 2. ENGAGEMENT BARRIER ANALYSIS BY GENDER
# Identifying the specific 'Awareness Gap' for Female veterans.
plt.figure(figsize=(12, 6))
sns.set_theme(style="whitegrid")
palette = {"Urban": "#004B87", "Rural": "#D21034"} # TVC Brand-adjacent colors

engagement_plot = sns.boxplot(
    x='gender',
    y='last_engagement_days_ago',
    hue='county_type',
    data=df,
    palette=palette
)

plt.title('Engagement Disparity: Days Since Contact by Gender & Geography (2026)', fontsize=15)
plt.xlabel('Veteran Gender Identification', fontsize=12)
plt.ylabel('Days Since Last Interaction', fontsize=12)
plt.axhline(365, ls='--', color='gray', label='12-Month Outreach Threshold')
plt.legend(title='County Type')
plt.savefig(os.path.join(output_dir, 'engagement_gap_boxplot.png'))

# 3. CORRELATION OF DISABILITY & DIGITAL RESPONSIVENESS
# Does a higher disability rating (GWII) lead to more or less outreach interaction?
correlation_matrix = df[['disability_rating', 'last_engagement_days_ago', 'outreach_clicks']].corr()

plt.figure(figsize=(8, 6))
sns.heatmap(correlation_matrix, annot=True, cmap='RdBu_r', center=0)
plt.title('Correlation: Needs vs. Digital Engagement', fontsize=14)
plt.savefig(os.path.join(output_dir, 'engagement_correlation_heatmap.png'))

# 4. SUMMARY STATISTICS FOR EXECUTIVE BRIEFING
# Generating a table for the Biennial Report
executive_summary = df.groupby(['era_of_service', 'county_type'])['outreach_clicks'].mean().unstack()
print("\n--- MEAN DIGITAL CLICKS BY ERA & REGION ---")
print(executive_summary)
